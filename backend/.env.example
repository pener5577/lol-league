# 服务器配置
PORT=3000

# MongoDB 连接地址
# 本地开发: mongodb://localhost:27017/lol-league
# 生产环境使用 MongoDB Atlas:
# mongodb+srv://<用户名>:<密码>@cluster0.xxxxx.mongodb.net/lol-league
MONGODB_URI=mongodb://localhost:27017/lol-league

# JWT 密钥（生产环境请使用复杂的随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 管理员初始化邀请码
ADMIN_INVITE_CODE=LOL_LEAGUE_ADMIN_2024
